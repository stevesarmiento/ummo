{
  "name": "ummo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=web --filter=@ummo/backend",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "init-market": "bun run scripts/init-market.ts"
  },
  "devDependencies": {
    "turbo": "^2.8.20"
  },
  "dependencies": {
    "@solana/kit": "5.5.1",
    "@solana/signers": "5.5.1",
    "@solana/transactions": "5.5.1",
    "@ummo/sdk": "workspace:*"
  }
}
